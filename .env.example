# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://username:password@cluster0.fpxktqt.mongodb.net/your-database-name

# Server Port (default: 5000)
PORT=5000

# Node Environment (development, production)
NODE_ENV=development

# SETUP INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Replace the placeholders with your actual MongoDB credentials
# 3. Get your connection string from: https://cloud.mongodb.com/
# 4. Never commit the .env file to git (it's in .gitignore)
