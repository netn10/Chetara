{
  "name": "chess-magic",
  "version": "1.0.0",
  "description": "Chess Magic - Where Magic: The Gathering meets Chess",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/server.js",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/server.js",
    "heroku-postbuild": "npm run build",
    "deploy": "git push heroku main",
    "deploy:setup": "heroku config:set NODE_ENV=production -a chetara",
    "deploy:logs": "heroku logs --tail -a chetara",
    "deploy:open": "heroku open -a chetara",
    "deploy:info": "heroku apps:info -a chetara",
    "populate": "node server/scripts/populateCards.js"
  },
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "keywords": [
    "magic",
    "chess",
    "cube"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chess.js": "^1.0.0-beta.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1",
    "vite": "^5.0.0",
    "vite-plugin-remove-console": "^2.2.0"
  }
}
